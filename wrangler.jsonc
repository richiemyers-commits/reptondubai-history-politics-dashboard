{
  "name": "reptondubai-history-politics-dashboard-dev",
  "main": "./src/worker.js",
  "compatibility_date": "2026-07-04",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*"
    ]
  }
}
